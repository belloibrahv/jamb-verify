# Database
DATABASE_URL="postgres://user:password@host/db"

# Auth
AUTH_SECRET="replace-with-strong-secret-minimum-32-characters"

# Paystack (Production)
PAYSTACK_PUBLIC_KEY="pk_live_..."
PAYSTACK_SECRET_KEY="sk_live_..."

# YouVerify (Production)
# IMPORTANT: Both variables are required for production
YOUVERIFY_TOKEN="your-production-youverify-token"
YOUVERIFY_BASE_URL="https://api.youverify.co/v2"

# Optional: Wallet Funding Limits
# Only set if you want to override the defaults
# MAX_WALLET_FUNDING_AMOUNT="100000000"  # Default: ₦1,000,000 in kobo

# ============================================
# OPTIONAL VARIABLES (Not currently used)
# ============================================
# These are placeholders for future features
# You can safely ignore them for now

# ENCRYPTION_KEY="your-encryption-key"
# MAX_DAILY_VERIFICATIONS_PER_USER="10"
# MIN_WALLET_FUNDING_AMOUNT="50000"
# SENTRY_DSN="your-sentry-dsn"
