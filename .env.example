# Database
DATABASE_URL="postgres://user:password@host/db"

# Auth
AUTH_SECRET="replace-with-strong-secret"

# Paystack
PAYSTACK_PUBLIC_KEY="pk_live_..."
PAYSTACK_SECRET_KEY="sk_live_..."

# YouVerify
