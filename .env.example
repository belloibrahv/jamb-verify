# Database
DATABASE_URL="postgres://user:password@host/db"

# Auth
AUTH_SECRET="replace-with-strong-secret"

# Paystack
PAYSTACK_PUBLIC_KEY="pk_live_..."
PAYSTACK_SECRET_KEY="sk_live_..."

# YouVerify
# SANDBOX LIMITATIONS:
# - Only test NIN allowed: 11111111111
# - Rate limit: Same NIN can only be verified once every 10 minutes
# - Other test NINs will return 403 Forbidden error
# 
# For production: Use production token and change base URL to https://api.youverify.co/v2
YOUVERIFY_TOKEN="your-youverify-sandbox-token"
YOUVERIFY_BASE_URL="https://api.sandbox.youverify.co/v2"
